# PostgreSQL connection string
# Local:      postgresql://user:password@localhost:5432/networth
# Supabase:   postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# Railway:    (copy from Railway dashboard)
DATABASE_URL=postgresql://user:password@localhost:5432/networth

# Port the Express server listens on (default: 3000)
PORT=3000

# Allowed CORS origin — set to your domain in production
# Leave as * during development
CORS_ORIGIN=*

# URL of the API server — used by the Expo frontend
# Development: http://localhost:3000
# Production:  https://your-vps-domain.com
EXPO_PUBLIC_API_URL=http://localhost:3000
